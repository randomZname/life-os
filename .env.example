# =====================================================================
# BogiAgent — environment configuration
# Copy към `.env` и попълни. НИКОГА не commit-вай `.env`.
# =====================================================================

# ----- Database -----
DATABASE_URL=postgresql+asyncpg://bogi:bogi@localhost:5432/bogi

# ----- LiteLLM proxy (модел gateway) -----
LITELLM_BASE_URL=http://localhost:4000
LITELLM_MASTER_KEY=sk-bogi-local-change-me

# Default model alias (избирай между: cheap | smart | premium)
DEFAULT_MODEL=smart

# ----- Provider API keys -----
# Anthropic е PRIMARY.
# OPENAI_API_KEY е FALLBACK — активира се при 401/429/5xx от Anthropic
# или ако заявка не се вписва в Claude context window. Силно препоръчано
# за production stability. Виж litellm/config.yaml -> litellm_settings.fallbacks.
# OPENAI_API_KEY също се ползва за Whisper voice transcription.
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GOOGLE_API_KEY=

# ----- ФМИ Moodle (parametrize за гъвкавост) -----
FMI_BASE_URL=https://learn.fmi.uni-sofia.bg
FMI_USERNAME=
FMI_PASSWORD=

# ----- Telegram -----
TELEGRAM_BOT_TOKEN=
# Comma-separated user IDs на хората, които могат да чатят с бота.
# Намираш своя ID през @userinfobot в Telegram.
TELEGRAM_ALLOWED_USER_IDS=

# ----- Paths -----
DATA_DIR=./data
VAULT_PATH=./vault

# ----- Embeddings -----
# Опция А (бърз старт): paraphrase-multilingual-MiniLM-L12-v2 (384d, ~120MB)
# Опция Б (по-добро BG): BAAI/bge-m3 (1024d, ~2GB)
EMBEDDING_MODEL=paraphrase-multilingual-MiniLM-L12-v2
EMBEDDING_DIMENSION=384

# ----- Cost guards -----
MONTHLY_SOFT_BUDGET_USD=30
MONTHLY_HARD_BUDGET_USD=100

# ----- Logging -----
LOG_LEVEL=INFO

# ----- Observability (Logfire) — OFF by default -----
# Leave LOGFIRE_TOKEN empty to keep tracing fully off (no data leaves the
# machine). To turn on: `pip install -e ".[observability]"`, create a Logfire
# project, paste its write token here. Set LOGFIRE_DISABLED=true to force-off
# even when a token is present. See docs/OBSERVABILITY_PLAN.md.
LOGFIRE_TOKEN=
LOGFIRE_DISABLED=
